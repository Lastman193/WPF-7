<Window x:Class="ComicVerse.Views.PersonalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource m_Profile}" Height="450" Width="350" 
        Background="{DynamicResource WindowBgBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="{DynamicResource m_Profile}" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center" Foreground="{DynamicResource MainTextBrush}"/>

            <TextBlock Text="{DynamicResource m_UserNameLabel}" Margin="0,5" Foreground="{DynamicResource MainTextBrush}"/>
            <TextBox Text="{Binding CurrentUser.Name, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="0,0,0,15" Height="28" VerticalContentAlignment="Center"/>

            <TextBlock Text="{DynamicResource m_InterfaceLang}" Margin="0,5" Foreground="{DynamicResource MainTextBrush}"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <Button Content="RU" Click="LangRu_Click" Width="50" Margin="0,0,5,0" Style="{StaticResource RoundButtonStyle}"/>
                <Button Content="EN" Click="LangEn_Click" Width="50" Style="{StaticResource RoundButtonStyle}"/>
            </StackPanel>

            <TextBlock Text="{DynamicResource m_ThemeLabel}" Margin="0,5" Foreground="{DynamicResource MainTextBrush}"/>
            <ComboBox x:Name="ThemeBox" 
                      SelectedValue="{Binding CurrentUser.SelectedTheme, UpdateSourceTrigger=PropertyChanged}"
                      SelectedValuePath="Tag"
                      SelectionChanged="Theme_Changed" Margin="0,0,0,25" Height="28">
                <ComboBoxItem Content="{DynamicResource m_ThemeLight}" Tag="Light"/>
                <ComboBoxItem Content="{DynamicResource m_ThemeDark}" Tag="Dark"/>
                <ComboBoxItem Content="{DynamicResource m_ThemePink}" Tag="Pink"/>
            </ComboBox>

            <Button Content="{DynamicResource m_Save}" Click="SaveAndClose_Click" Height="40" 
                    Background="#4CAF50" Foreground="White" FontWeight="Bold" Style="{StaticResource RoundButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>