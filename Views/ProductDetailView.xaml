<UserControl x:Class="ComicVerse.Views.ProductDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="900">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Margin="40">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel>
            <Border CornerRadius="15" Background="#EEE" ClipToBounds="True" Height="450" VerticalAlignment="Top">
                <Image Source="{Binding ImagePaths[0]}" Stretch="UniformToFill"/>
            </Border>
            <Button Content="{DynamicResource m_ImagePath}" Click="ChangePhoto_Click" Margin="0,10" Height="30"
                    Visibility="{Binding DataContext.IsAdminMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
        </StackPanel>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40,0,0,0">
                <TextBlock Text="{DynamicResource m_Name}" FontWeight="Bold" Margin="0,0,0,5" Foreground="{DynamicResource MainTextBrush}"/>
                <TextBox Text="{Binding ShortName, UpdateSourceTrigger=PropertyChanged}" FontSize="24" Margin="0,0,0,20"
                         IsEnabled="{Binding DataContext.IsAdminMode, RelativeSource={RelativeSource AncestorType=Window}}"/>

                <TextBlock Text="{DynamicResource m_Category}" FontWeight="Bold" Margin="0,0,0,5" Foreground="{DynamicResource MainTextBrush}"/>
                <ComboBox SelectedValue="{Binding Category, UpdateSourceTrigger=PropertyChanged}" 
          SelectedValuePath="Tag"
          Height="30" Margin="0,0,0,15" VerticalContentAlignment="Center"
          IsEnabled="{Binding DataContext.IsAdminMode, RelativeSource={RelativeSource AncestorType=Window}}">
                    <ComboBoxItem Content="{DynamicResource cat_Manga}" Tag="Манга"/>
                    <ComboBoxItem Content="{DynamicResource cat_Comic}" Tag="Комикс"/>
                    <ComboBoxItem Content="Ранобэ" Tag="Ранобэ"/>
                </ComboBox>

                <TextBlock Text="{DynamicResource m_Description}" FontWeight="Bold" Margin="0,0,0,5" Foreground="{DynamicResource MainTextBrush}"/>
                <TextBox Text="{Binding Description}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="120" Margin="0,0,0,15"
                         IsEnabled="{Binding DataContext.IsAdminMode, RelativeSource={RelativeSource AncestorType=Window}}"/>

                <TextBlock Text="{DynamicResource m_Price}" FontWeight="Bold" Margin="0,0,0,5" Foreground="{DynamicResource MainTextBrush}"/>
                <TextBox Text="{Binding Price, UpdateSourceTrigger=PropertyChanged}" FontSize="20" Margin="0,0,0,25"
                         IsEnabled="{Binding DataContext.IsAdminMode, RelativeSource={RelativeSource AncestorType=Window}}"/>

                <StackPanel Orientation="Horizontal">
                    <Button Content="{DynamicResource m_Save}" Click="Save_Click" Width="150" Height="40" Background="#4CAF50" Foreground="White"
                            Visibility="{Binding DataContext.IsAdminMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"
                            Style="{StaticResource RoundButtonStyle}" Margin="0,0,10,0"/>

                    <Button Content="{DynamicResource m_Back}" Click="Back_Click" Width="150" Height="40" Background="#666" Foreground="White"
                            Style="{StaticResource RoundButtonStyle}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>