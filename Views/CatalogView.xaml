<UserControl x:Class="ComicVerse.Views.CatalogView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:m="clr-namespace:ComicVerse.Models">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
            <ItemsControl ItemsSource="{Binding Main.ItemsView}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Left"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type m:ComicItem}">
                        <Border Style="{StaticResource AnimatedCardStyle}" Width="220" Height="360" Margin="10">
                            <Grid>
                                <StackPanel Margin="10" MouseDown="Card_MouseDown" Cursor="Hand" Background="Transparent">
                                    <Image Source="{Binding ImagePaths[0]}" Height="200" Stretch="UniformToFill"/>
                                    <TextBlock Text="{Binding ShortName}" FontWeight="Bold" Margin="0,10,0,2" 
                                                   FontSize="14" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource MainTextBrush}"/>
                                    <TextBlock Text="{Binding Category}" FontSize="11" Foreground="Gray" Margin="0,0,0,5"/>
                                    <TextBlock Grid.Row="3" FontWeight="Bold" FontSize="16" Margin="0,5,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#E91E63"/>
                                                <Setter Property="Text" Value="{Binding Price, StringFormat='{}{0} BYN'}"/>

                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsExpensive}" Value="True">
                                                        <Setter Property="Foreground" Value="Yellow"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <Button Content="✕" 
                                            VerticalAlignment="Top" HorizontalAlignment="Right"
                                            Width="30" Height="30" Margin="5"
                                            Background="#FF5252" Foreground="White"
                                            Command="{Binding DataContext.Main.RemoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Visibility="{Binding DataContext.IsAdminMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"
                                            Style="{StaticResource RoundButtonStyle}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>