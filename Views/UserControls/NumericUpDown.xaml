<UserControl x:Class="ComicVerse.Views.UserControls.NumericUpDown"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="100" Height="30">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="30"/>
        </Grid.ColumnDefinitions>
        <TextBox x:Name="ValueHolder" Text="1" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" IsReadOnly="True"/>
        <StackPanel Grid.Column="1">
            <Button Content="▲" Height="15" FontSize="8" Click="Up_Click"/>
            <Button Content="▼" Height="15" FontSize="8" Click="Down_Click"/>
        </StackPanel>
    </Grid>
</UserControl>