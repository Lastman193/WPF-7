<Window x:Class="ComicVerse.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:v="clr-namespace:ComicVerse.Views"
        xmlns:vm="clr-namespace:ComicVerse.ViewModels"
        xmlns:m="clr-namespace:ComicVerse.Models"
        xmlns:uc="clr-namespace:ComicVerse.Views.UserControls"
        Title="ComicVerse Store" Height="750" Width="1200" 
        Background="{DynamicResource WindowBgBrush}" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <DataTemplate DataType="{x:Type vm:CatalogViewModel}">
            <v:CatalogView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type m:ComicItem}">
            <v:ProductDetailView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="{DynamicResource CardBgBrush}" BorderBrush="#DDD" BorderThickness="0,0,1,0">
            <StackPanel Margin="20">
                <TextBlock Text="ComicVerse" FontSize="24" FontWeight="Bold" Foreground="#5C6BC0" 
                           Cursor="Hand" MouseDown="GoToCatalog_Click" Margin="0,0,0,20"/>

                <TextBlock Text="{DynamicResource m_Price}" Foreground="{DynamicResource MainTextBrush}" Margin="0,0,0,5"/>
                <uc:NumericUpDown Value="{Binding MinPrice, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20"/>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="←" Click="BackNav_Click" IsEnabled="{Binding CanGoBack}" 
                            Margin="0,0,5,0" Style="{StaticResource RoundButtonStyle}" Height="35"/>
                    <Button Content="→" Click="Redo_Click" IsEnabled="{Binding CanRedo}" 
                            Grid.Column="1" Style="{StaticResource RoundButtonStyle}" Height="35"/>
                </Grid>

                <Button Content="{DynamicResource m_Catalog}" Click="GoToCatalog_Click" Height="40" Margin="0,0,0,10" Style="{StaticResource RoundButtonStyle}"/>
                <Button Content="{DynamicResource m_Profile}" Click="OpenPersonal_Click" Height="40" Margin="0,0,0,10" Style="{StaticResource RoundButtonStyle}"/>

                <Button Content="{DynamicResource m_Add}" 
                        Visibility="{Binding IsAdminMode, Converter={StaticResource BoolToVis}}"
                        Click="AddProduct_Click" Height="40" Margin="0,0,0,10" 
                        Style="{StaticResource RoundButtonStyle}" Background="#4CAF50"/>

                <Separator Margin="0,10"/>
                <CheckBox Content="{DynamicResource m_AdminMode}" IsChecked="{Binding IsAdminMode}" Margin="0,10"/>
            </StackPanel>
        </Border>

        <ContentControl Grid.Column="1" Content="{Binding CurrentView}"/>
    </Grid>
</Window>