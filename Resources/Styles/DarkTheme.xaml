<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="WindowBgColor">#1E1E1E</Color>
    <Color x:Key="CardBgColor">#2D2D2D</Color>
    <Color x:Key="PrimaryTextColor">#E0E0E0</Color>
    <Color x:Key="AccentColor">#BB86FC</Color>

    <SolidColorBrush x:Key="WindowBgBrush" Color="{StaticResource WindowBgColor}"/>
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBgColor}"/>
    <SolidColorBrush x:Key="MainTextBrush" Color="{StaticResource PrimaryTextColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
</ResourceDictionary>